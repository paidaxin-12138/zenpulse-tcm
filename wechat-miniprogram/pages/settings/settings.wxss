.page { padding: 32rpx; background: #f9f9f7; min-height: 100vh; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 24rpx rgba(108,47,0,.06); }
.title { display: block; font-size: 32rpx; font-weight: 600; color: #6c2f00; margin-bottom: 12rpx; }
.hint { display: block; font-size: 24rpx; color: #877369; margin-bottom: 20rpx; line-height: 1.5; }
.input { border: 1px solid #e0dcd8; border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 26rpx; margin-bottom: 20rpx; }
.row { display: flex; gap: 16rpx; flex-wrap: wrap; margin-bottom: 16rpx; }
.btn { flex: 1; min-width: 200rpx; font-size: 26rpx; border-radius: 999rpx; }
.btn.primary { background: #6c2f00; color: #fff; }
.btn.ghost { background: transparent; color: #877369; border: 1px solid #e0dcd8; }
.label { display: block; font-size: 24rpx; color: #877369; }
.mono { display: block; font-size: 24rpx; word-break: break-all; margin: 8rpx 0 12rpx; color: #333; }
.status { font-size: 24rpx; }
.status.ok { color: #2e7d32; }
.status.err { color: #c62828; }
.check-item { display: block; font-size: 24rpx; color: #555; line-height: 1.6; margin-top: 8rpx; }

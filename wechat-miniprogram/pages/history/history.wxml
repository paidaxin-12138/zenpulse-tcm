<view class="zp-page">
  <text class="zp-display" style="margin-bottom:8rpx">诊断历史</text>
  <text class="zp-body-sm" style="margin-bottom:32rpx">查看所有历史诊断记录</text>

  <view class="zp-list-group zp-glass" wx:if="{{diagnosisHistory.length > 0}}">
    <block wx:for="{{diagnosisHistory}}" wx:key="index">
      <view class="zp-list-item" bindtap="showHistoryDetail" data-index="{{index}}" style="flex-direction:column;align-items:flex-start">
        <view style="display:flex;width:100%;justify-content:space-between;align-items:center">
          <text class="zp-body-sm">{{formatDate(item.timestamp || item.time)}}</text>
          <text class="zp-badge-green">已完成</text>
        </view>
        <text class="zp-list-title" style="margin-top:12rpx;font-weight:400">{{item.syndrome || item.diagnosis || '诊断记录'}}</text>
        <text wx:if="{{item.healthMetrics && item.healthMetrics.heartRate}}" class="zp-body-sm" style="margin-top:8rpx;font-size:26rpx">心率 {{item.healthMetrics.heartRate}} · 血压 {{item.healthMetrics.systolic}}/{{item.healthMetrics.diastolic}}</text>
      </view>
    </block>
  </view>

  <view class="zp-card zp-glass" wx:if="{{diagnosisHistory.length === 0}}">
    <image class="zp-empty-hero" src="/images/zenpulse/card-goji.jpg" mode="aspectFill"></image>
    <view class="zp-empty">
      <text class="zp-headline" style="font-size:40rpx;display:block;margin-bottom:12rpx">暂无诊断记录</text>
      <text class="zp-body-sm" style="margin-bottom:32rpx">完成首次诊断后，记录将显示在这里</text>
      <button class="zp-btn-primary" bindtap="startNewDiagnosis">开始新诊断</button>
    </view>
  </view>

  <block wx:if="{{diagnosisHistory.length > 0}}">
    <view class="zp-list-group zp-glass" style="margin-top:32rpx">
      <button class="zp-btn-destructive" bindtap="clearHistory">清空历史记录</button>
    </view>
    <button class="zp-btn-primary" bindtap="startNewDiagnosis">开始新诊断</button>
  </block>
</view>

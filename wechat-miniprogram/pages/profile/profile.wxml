<view class="zp-page">
  <view class="zp-profile-banner">
    <image class="zp-profile-banner-img" src="/images/zenpulse/card-herbs.jpg" mode="aspectFill"></image>
    <view class="zp-profile-banner-mask"></view>
  </view>
  <view class="zp-profile-header">
    <button wx:if="{{isLoggedIn}}" class="zp-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <view class="zp-avatar-wrap">
        <view class="zp-avatar">
          <image wx:if="{{userInfo.avatarUrl}}" class="zp-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
          <text wx:else class="zp-avatar-ph">我</text>
        </view>
      </view>
    </button>
    <view wx:else class="zp-avatar-wrap">
      <view class="zp-avatar"><text class="zp-avatar-ph">我</text></view>
    </view>
    <input
      wx:if="{{isLoggedIn}}"
      class="zp-display"
      style="font-size:48rpx;text-align:center;margin-bottom:8rpx"
      type="nickname"
      placeholder="点击设置昵称"
      value="{{userInfo.nickName}}"
      bindblur="onNicknameBlur"
    />
    <text wx:else class="zp-display" style="font-size:48rpx">{{userInfo.nickName}}</text>
    <text class="zp-body-sm">{{isLoggedIn ? '养生之境，在乎清心' : '登录后同步云端历史'}}</text>
  </view>

  <view class="zp-card zp-glass zp-stat-card">
    <view>
      <text class="zp-label" style="opacity:0.6">诊断记录</text>
      <text class="zp-stat-num">{{diagnosisHistory.length}} <text class="zp-body-sm" style="font-weight:400">次调理</text></text>
    </view>
    <view class="zp-icon-box"><text class="zp-icon-text">统</text></view>
  </view>

  <button wx:if="{{!isLoggedIn}}" class="zp-btn-primary" loading="{{loginLoading}}" bindtap="onLoginTap">微信登录</button>

  <view class="zp-list-group zp-glass">
    <view class="zp-list-item" bindtap="showDiagnosisHistory">
      <view class="zp-list-icon zp-list-icon-warm">历</view>
      <view class="zp-list-body"><text class="zp-list-title">诊断历史</text></view>
      <text class="zp-list-chevron">›</text>
    </view>
    <view class="zp-list-item" bindtap="showSettings">
      <view class="zp-list-icon zp-list-icon-warm">设</view>
      <view class="zp-list-body"><text class="zp-list-title">服务器设置</text></view>
      <text class="zp-list-chevron">›</text>
    </view>
    <view class="zp-list-item" bindtap="showHelp">
      <view class="zp-list-icon zp-list-icon-gold">?</view>
      <view class="zp-list-body"><text class="zp-list-title">帮助与反馈</text></view>
      <text class="zp-list-chevron">›</text>
    </view>
    <view class="zp-list-item" bindtap="showAbout">
      <view class="zp-list-icon zp-list-icon-peach">i</view>
      <view class="zp-list-body"><text class="zp-list-title">关于我们</text></view>
      <text class="zp-list-chevron">›</text>
    </view>
  </view>

  <view class="zp-list-group zp-glass zp-platform-dock">
    <text class="zp-platform-label">ZenPulse 全平台</text>
    <view class="zp-platform-row">
      <view class="zp-platform-chip" bindtap="openWebClient">
        <text class="zp-platform-chip-text">Web 用户端</text>
      </view>
    </view>
    <text class="zp-caption zp-platform-hint">{{platformHint}}</text>
  </view>

  <text class="zp-label" style="margin-left:8rpx">最近记录</text>
  <view class="zp-list-group zp-glass">
    <block wx:for="{{diagnosisHistory}}" wx:key="id">
      <view class="zp-list-item" bindtap="showHistoryDetail" data-index="{{index}}" style="flex-direction:column;align-items:flex-start">
        <view style="display:flex;width:100%;justify-content:space-between;align-items:center">
          <text class="zp-body-sm">{{formatDate(item.timestamp || item.time)}}</text>
          <text class="zp-badge-green">已完成</text>
        </view>
        <text class="zp-list-title" style="margin-top:12rpx;font-weight:400">{{item.syndrome || item.diagnosis || '诊断记录'}}</text>
      </view>
    </block>
    <block wx:if="{{diagnosisHistory.length === 0}}">
      <view class="zp-empty">
        <text class="zp-headline" style="font-size:36rpx;display:block;margin-bottom:8rpx">暂无记录</text>
        <text class="zp-body-sm">完成诊断后将显示在这里</text>
      </view>
    </block>
  </view>

  <view class="zp-list-group zp-glass" wx:if="{{isLoggedIn}}">
    <button class="zp-btn-destructive" bindtap="onLogoutTap">退出登录</button>
  </view>

  <button class="zp-btn-primary" bindtap="startNewDiagnosis">开始新诊断</button>
  <text class="zp-caption">版本 v1.1.0 · © 2026 御心调理</text>
</view>

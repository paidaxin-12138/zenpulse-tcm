/* ZenPulse Premium iOS — from stitch_zenpulse_mini */

page {
  background-color: #f9f9f7;
  color: #1a1c1b;
  font-family: -apple-system, 'PingFang SC', 'Noto Serif SC', 'Helvetica Neue', sans-serif;
  line-height: 1.5;
}

.zp-page {
  min-height: 100vh;
  padding: 24rpx 40rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.zp-page-footer-fixed {
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.zp-display {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1c1b;
  line-height: 1.2;
  letter-spacing: -1rpx;
}

.zp-display-primary {
  color: #6c2f00;
}

.zp-headline {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #6c2f00;
  line-height: 1.3;
}

.zp-body {
  font-size: 34rpx;
  color: #1a1c1b;
  line-height: 1.5;
}

.zp-body-sm {
  display: block;
  font-size: 30rpx;
  color: #54433a;
  line-height: 1.4;
}

.zp-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #54433a;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 12rpx;
  padding-left: 24rpx;
}

.zp-label-primary {
  color: #6c2f00;
  letter-spacing: 0.1em;
}

.zp-section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 32rpx 0 24rpx;
}

.zp-card {
  background: #ffffff;
  border-radius: 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  margin-bottom: 32rpx;
}

.zp-glass {
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.zp-hero {
  position: relative;
  height: 560rpx;
  border-radius: 48rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.04);
}

.zp-hero-img {
  width: 100%;
  height: 100%;
}

.zp-hero-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent 60%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 48rpx;
}

.zp-hero-kicker {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  letter-spacing: 0.15em;
  margin-bottom: 8rpx;
}

.zp-hero-title {
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.2;
}

.zp-btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #6c2f00;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: none;
  box-shadow: 0 16rpx 40rpx rgba(108, 47, 0, 0.25);
  margin-bottom: 24rpx;
  padding: 0;
}

.zp-btn-primary::after {
  border: none;
}

.zp-btn-secondary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #6c2f00;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: 1rpx solid rgba(218, 194, 182, 0.6);
  margin-bottom: 16rpx;
  padding: 0;
}

.zp-btn-secondary::after {
  border: none;
}

.zp-btn-plain {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: transparent;
  color: #944925;
  font-size: 30rpx;
  border: none;
  padding: 0;
}

.zp-btn-plain::after {
  border: none;
}

.zp-btn-destructive {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #ffffff;
  color: #ba1a1a;
  font-size: 34rpx;
  border-radius: 32rpx;
  border: none;
  padding: 0;
}

.zp-btn-destructive::after {
  border: none;
}

.zp-bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.zp-bento-item {
  background: #ffffff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.04);
}

.zp-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: rgba(108, 47, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.zp-icon-box-secondary {
  background: rgba(148, 73, 37, 0.05);
}

.zp-icon-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #6c2f00;
}

.zp-icon-text-secondary {
  color: #944925;
}

.zp-chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 256rpx;
  gap: 12rpx;
  padding: 0 8rpx;
  margin-bottom: 24rpx;
}

.zp-bar {
  flex: 1;
  border-radius: 999rpx;
  min-height: 20rpx;
}

.zp-bar-1 { background: #ffdbcd; height: 40%; }
.zp-bar-2 { background: #944925; height: 70%; }
.zp-bar-3 { background: #ffdbcd; height: 55%; }
.zp-bar-4 { background: #fe9e72; height: 85%; }
.zp-bar-5 { background: #6c2f00; height: 60%; }
.zp-bar-6 { background: #ffdbcd; height: 45%; }
.zp-bar-7 { background: #944925; height: 90%; }

.zp-chart-labels {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #54433a;
}

.zp-tip-card {
  display: flex;
  gap: 32rpx;
  padding: 48rpx;
}

.zp-tip-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(82, 61, 30, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 40rpx;
}

.zp-step-wrap {
  text-align: center;
  padding: 32rpx 0 24rpx;
}

.zp-step-dots {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.zp-step-dot {
  width: 64rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e2e3e1;
}

.zp-step-dot-active {
  background: #6c2f00;
}

.zp-banner-img {
  position: relative;
  height: 360rpx;
  border-radius: 48rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.zp-banner-img .zp-banner-img-el {
  width: 100%;
  height: 100%;
}

.zp-banner-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
  color: #ffffff;
}

.zp-field {
  margin-bottom: 32rpx;
}

.zp-input-wrap {
  position: relative;
}

.zp-input {
  width: 100%;
  height: 112rpx;
  background: #ffffff;
  border-radius: 32rpx;
  border: 1rpx solid rgba(218, 194, 182, 0.5);
  padding-left: 56rpx;
  padding-right: 56rpx;
  font-size: 34rpx;
  color: #1a1c1b;
  box-sizing: border-box;
  text-align: left;
}

.zp-input-wrap-unit .zp-input {
  padding-right: 140rpx;
}

.zp-input-unit {
  position: absolute;
  right: 56rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 30rpx;
  color: #54433a;
}

.zp-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
}

.zp-bp-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.zp-bp-sep {
  font-size: 40rpx;
  color: #dac2b6;
  font-weight: 700;
}

.zp-segment {
  display: flex;
  background: #eeeeec;
  border-radius: 32rpx;
  padding: 8rpx;
  height: 96rpx;
}

.zp-segment-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  color: #54433a;
  border-radius: 24rpx;
}

.zp-segment-item.selected {
  background: #ffffff;
  color: #6c2f00;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.zp-footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 40rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 -20rpx 60rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.zp-upload-card {
  border-radius: 48rpx;
  border: 3rpx dashed rgba(135, 115, 105, 0.5);
  background: rgba(255, 255, 255, 0.7);
  min-height: 352rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  margin-bottom: 24rpx;
}

.zp-upload-card-done {
  border-style: solid;
  border-color: #934b19;
  background: #ffdbcd;
}

.zp-upload-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(108, 47, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #6c2f00;
  margin-bottom: 16rpx;
}

.zp-upload-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #6c2f00;
  margin-bottom: 8rpx;
}

.zp-preview {
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.zp-preview-img {
  width: 100%;
  height: 352rpx;
  display: block;
}

.zp-preview-actions {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.zp-preview-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.zp-preview-del {
  background: rgba(186, 26, 26, 0.1);
  color: #ba1a1a;
}

.zp-preview-re {
  background: rgba(108, 47, 0, 0.1);
  color: #6c2f00;
}

.zp-score-ring {
  width: 256rpx;
  height: 256rpx;
  border-radius: 50%;
  border: 12rpx solid #e2e3e1;
  border-top-color: #6c2f00;
  border-right-color: #6c2f00;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
}

.zp-score-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #6c2f00;
}

.zp-chip-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.zp-chip {
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(108, 47, 0, 0.1);
  color: #6c2f00;
  font-size: 20rpx;
  font-weight: 600;
}

.zp-report-card {
  padding: 48rpx;
}

.zp-report-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(218, 194, 182, 0.5);
  margin-bottom: 24rpx;
}

.zp-report-icon {
  font-size: 36rpx;
  color: #6c2f00;
}

.zp-list-group {
  border-radius: 40rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.zp-list-item {
  display: flex;
  align-items: center;
  padding: 32rpx 48rpx;
  background: rgba(255, 255, 255, 0.9);
  border-bottom: 1rpx solid rgba(226, 227, 225, 0.8);
}

.zp-list-item:last-child {
  border-bottom: none;
}

.zp-list-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
  font-size: 32rpx;
}

.zp-list-icon-warm { background: #ffdbcd; color: #944925; }
.zp-list-icon-gold { background: #feddb3; color: #523d1e; }
.zp-list-icon-gray { background: #e2e3e1; color: #54433a; }
.zp-list-icon-peach { background: #ffdbc9; color: #6c2f00; }

.zp-list-body {
  flex: 1;
}

.zp-list-title {
  font-size: 34rpx;
  color: #1a1c1b;
}

.zp-list-chevron {
  font-size: 36rpx;
  color: #dac2b6;
}

.zp-profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 32rpx 0 48rpx;
  margin-top: -48rpx;
  position: relative;
  z-index: 2;
}

.zp-avatar-wrap {
  position: relative;
  margin-bottom: 24rpx;
}

.zp-avatar {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  border: 8rpx solid #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  background: #f4f4f2;
}

.zp-avatar-img {
  width: 192rpx;
  height: 192rpx;
}

.zp-avatar-ph {
  width: 192rpx;
  height: 192rpx;
  line-height: 192rpx;
  text-align: center;
  font-size: 64rpx;
  color: #877369;
}

.zp-avatar-btn {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: 1;
}

.zp-avatar-btn::after {
  border: none;
}

.zp-stat-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx;
}

.zp-stat-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #6c2f00;
}

.zp-badge-green {
  font-size: 22rpx;
  color: #6c2f00;
  background: rgba(108, 47, 0, 0.08);
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
}

.zp-empty {
  padding: 80rpx 48rpx;
  text-align: center;
}

.zp-caption {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(84, 67, 58, 0.5);
  margin-top: 24rpx;
}

.zp-quote {
  text-align: center;
  padding: 32rpx;
  font-size: 28rpx;
  color: #877369;
  font-style: italic;
}

.zp-disclaimer {
  font-size: 26rpx;
  color: #54433a;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.zp-primary-banner {
  background: #6c2f00;
  color: #ffffff;
  border-radius: 48rpx;
  padding: 48rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 24rpx 48rpx rgba(108, 47, 0, 0.2);
}

.zp-link-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.zp-link-row:not(:last-child) {
  border-bottom: 1rpx solid rgba(218, 194, 182, 0.4);
}

/* Bento with photo */
.zp-bento-photo {
  position: relative;
  padding: 0;
  overflow: hidden;
  min-height: 280rpx;
}

.zp-bento-bg {
  width: 100%;
  height: 280rpx;
  display: block;
}

.zp-bento-overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 32rpx;
  background: linear-gradient(to top, rgba(34, 26, 22, 0.75), transparent);
}

.zp-bento-title {
  display: block;
  font-size: 36rpx;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.zp-bento-desc {
  color: rgba(255, 255, 255, 0.85);
}

/* Herb horizontal scroll */
.zp-herb-scroll {
  white-space: nowrap;
  margin-bottom: 32rpx;
  width: 100%;
}

.zp-herb-card {
  display: inline-block;
  width: 240rpx;
  margin-right: 24rpx;
  vertical-align: top;
}

.zp-herb-card:last-child {
  margin-right: 0;
}

.zp-herb-img {
  width: 240rpx;
  height: 240rpx;
  border-radius: 32rpx;
  display: block;
  box-shadow: 0 12rpx 32rpx rgba(108, 47, 0, 0.12);
}

.zp-herb-name {
  display: block;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #6c2f00;
  margin-top: 16rpx;
}

/* Tip card with photo */
.zp-tip-photo {
  display: flex;
  overflow: hidden;
  padding: 0;
}

.zp-tip-photo-img {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.zp-tip-photo-body {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Profile top banner */
.zp-profile-banner {
  position: relative;
  height: 240rpx;
  margin: -24rpx -40rpx 0;
  overflow: hidden;
}

.zp-profile-banner-img {
  width: 100%;
  height: 100%;
}

.zp-profile-banner-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, rgba(34, 26, 22, 0.15), rgba(249, 249, 247, 0.95));
}

/* Result top banner */
.zp-result-banner {
  position: relative;
  height: 200rpx;
  margin: -24rpx -40rpx 16rpx;
  overflow: hidden;
  border-radius: 0 0 48rpx 48rpx;
}

.zp-result-banner-img {
  width: 100%;
  height: 100%;
}

.zp-result-banner-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent, rgba(249, 249, 247, 1));
}

.zp-empty-hero {
  width: 100%;
  height: 320rpx;
  display: block;
  border-radius: 48rpx 48rpx 0 0;
}

.zp-platform-dock {
  padding: 32rpx 40rpx !important;
  background: rgba(255, 241, 233, 0.92) !important;
}

.zp-platform-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #877369;
  margin-bottom: 20rpx;
  text-transform: uppercase;
}

.zp-platform-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.zp-platform-chip {
  flex: 1;
  text-align: center;
  padding: 20rpx 16rpx;
  background: #fff;
  border-radius: 999rpx;
  border: 1rpx solid rgba(218, 194, 182, 0.8);
}

.zp-platform-chip-muted {
  background: rgba(255, 255, 255, 0.6);
}

.zp-platform-chip-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #6c2f00;
}

.zp-platform-hint {
  display: block;
  text-align: center;
  margin-top: 8rpx;
  line-height: 1.5;
}
